# Environment Variables for Multi-tenant RAG System

# Ollama Configuration
OLLAMA_HOST=localhost
OLLAMA_PORT=11434

# Disable Telemetry (Required)
GROQ_DISABLE_TELEMETRY=1
CHROMADB_ALLOW_TELEMETRY=false
CHROMA_TELEMETRY_DISABLED=1
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ANALYTICS=false
OLLAMA_TELEMETRY=false

# Optional: Set Python path for module imports
# PYTHONPATH=.

# Optional: Logging level
# LOG_LEVEL=INFO

# LangChain Configuration (Optional - for advanced features)
# LANGCHAIN_API_KEY=your_langchain_api_key_here
# LANGCHAIN_PROJECT=your_project_name

# HuggingFace Configuration (Optional - for custom embeddings)
# HUGGINGFACE_API_TOKEN=your_hf_token_here

# Note: No API keys required for local Ollama + ChromaDB setup
# If using external LLM providers, add their API keys here:
# GROQ_API_KEY=your_groq_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here